#include <iostream>
using namespace std;
int main()
{
    int n;
    cout << "enter the number:";
    cin >> n;
    int arr1[n];
    int arr2[n];
    for (int i = 0; i < n; i++)
    {
        cout << "enter the " << i + 1 << " element. :";
        cin >> arr1[i];
    }
    for (int i = 0; i < n; i++)
    {
        arr2[i] = arr1[n - 1 - i];
        cout << arr2[i] << " ";
    }
}
